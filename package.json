{
  "name": "bee-updater",
  "version": "2.0.0",
  "description": "Multi-state tax table updater with deterministic PDF extraction",
  "main": "main.js",
  "scripts": {
    "test": "node --test",
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.hrblock.bee-updater",
    "productName": "Bee Updater",
    "win": {
      "target": "nsis",
      "artifactName": "Bee-Updater-Setup-${version}.${ext}"
    },
    "files": [
      "main.js",
      "pathUtils.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "States/**",
      "assets/**"
    ],
    "nsis": {
      "shortcutName": "Bee Updater",
      "uninstallDisplayName": "Bee Updater",
      "artifactName": "Bee-Updater-Setup-${version}.${ext}"
    },
    "executableName": "BeeUpdater"
  },
  "dependencies": {
    "pdfjs-dist": "^4.8.69"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0",
    "electron": "^28.0.0"
  },
  "author": "H&R Block"
}
