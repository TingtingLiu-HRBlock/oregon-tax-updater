{
  "name": "state-tax-updater",
  "version": "2.0.0",
  "description": "Multi-state tax table updater with PDF and screenshot extraction",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.hrblock.state-tax-updater",
    "productName": "State Tax Table Updater",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "states/**",
      "assets/**"
    ]
  },
  "dependencies": {
    "electron": "^28.0.0",
    "pdfjs-dist": "^4.8.69"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  }
}

